# Copiá este archivo a deploy.config y completá los valores.
# deploy.config está en .gitignore — no commitear credenciales.

# ── Conexión SSH ──────────────────────────────────────────────
VPS_HOST=185.166.212.91
VPS_USER=root
SSH_PORT=22
# SSH_KEY=~/.ssh/id_rsa          # opcional, si no usás el agente SSH

# ── App ───────────────────────────────────────────────────────
# Si ya tenés el código en el home del usuario (ej. ~/claude_whats),
# usá esa ruta — no hace falta /opt ni sudo:
#   APP_DIR=/home/cto/claude_whats
#   GIT_REPO=   # vacío = usar el código local (git pull si hay .git)
#
# Solo usá /opt si el usuario puede escribir ahí (root o chown previo):
APP_DIR=/home/cto/claude_whats
GIT_REPO=
GIT_BRANCH=main
APP_PORT=3000
NODE_MAJOR=22

# ── Nginx (opcional) ──────────────────────────────────────────
# Si definís DOMAIN, el script configura Nginx como reverse proxy.
# Luego corré: certbot --nginx -d bot.tudominio.com
DOMAIN=
SKIP_NGINX=0

# ── Deploy remoto ─────────────────────────────────────────────
# SYNC_LOCAL=1  → rsync del código local en lugar de git pull (solo en deploy)
