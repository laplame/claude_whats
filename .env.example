# Claude (Anthropic) — proveedor principal del LLM
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5

# Gemini (Google) — fallback automático si Claude falla (rate limit, error, etc.)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# MongoDB Atlas — respaldo opcional de la base SQLite (best-effort, no bloqueante).
# Si se deja vacía, el bot funciona 100% con SQLite local, sin ningún cambio de
# comportamiento. Las lecturas del dashboard SIEMPRE vienen de SQLite; Mongo solo
# recibe una copia de cada escritura como histórico/backup.
MONGODB_URI=
MONGODB_DB_NAME=agente_whatsapp

# Auth del dashboard — usuario admin inicial (solo se crea si no hay usuarios).
# Login con email O whatsapp + passcode.
AUTH_ADMIN_EMAIL=saul.laplame@gmail.com
AUTH_ADMIN_WHATSAPP=5215577238143
AUTH_ADMIN_PASSCODE=8044
AUTH_ADMIN_NAME=Saul

# Permitir registro público (sign up). Poné false para solo login.
AUTH_ALLOW_SIGNUP=true

# Cookie de sesión Secure (HTTPS). En VPS por http://IP:PUERTO dejalo en false
# o sin definir (si no hay DOMAIN). Con HTTPS + dominio: COOKIE_SECURE=true
COOKIE_SECURE=false

# Minutos de inactividad humana antes de que el modo vuelva a IA automáticamente
HUMAN_MODE_TIMEOUT_MINUTES=30

# Nivel de logs del bot: error | warn | info (default) | debug
BOT_LOG_LEVEL=info

# Nivel de logs internos de Baileys (librería): silent (default) | trace | debug | info
BAILEYS_LOG_LEVEL=silent