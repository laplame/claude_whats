# Claude (Anthropic) — proveedor principal del LLM
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5

# Gemini (Google) — fallback automático si Claude falla (rate limit, error, etc.)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# MongoDB Atlas — respaldo opcional de la base SQLite (best-effort, no bloqueante).
# Si se deja vacía, el bot funciona 100% con SQLite local, sin ningún cambio de
# comportamiento. Las lecturas del dashboard SIEMPRE vienen de SQLite; Mongo solo
# recibe una copia de cada escritura como histórico/backup.
MONGODB_URI=
MONGODB_DB_NAME=agente_whatsapp
